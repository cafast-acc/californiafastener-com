# California Fastener — env template
# Copy to .env.local for local dev. In Vercel, set the same vars under
# Project Settings → Environment Variables for Production + Preview + Development.

# ─── Supabase (Phase 1) ──────────────────────────────────
# From Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...replace-me...

# Server-only — bypasses RLS. NEVER expose. Used by seed scripts / webhooks
# in later phases. Phase 1 app code does NOT import this.
SUPABASE_SERVICE_ROLE_KEY=eyJ...replace-me...
