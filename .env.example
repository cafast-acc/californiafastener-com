# Sanity — Field Notes blog
# Copy to .env.local and fill in. Vercel: set the same vars under Project Settings → Environment.

# From sanity.io → Manage → API
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Pin to a date. Don't auto-track — bumping is a deliberate API choice.
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-01

# Optional. Required for draft-mode preview reads (unpublished posts).
SANITY_API_READ_TOKEN=

# Shared secret for the /api/revalidate webhook. Generate with `openssl rand -hex 32`.
# Paste the same value into Sanity → Manage → API → GROQ-powered Webhooks → Secret.
SANITY_REVALIDATE_SECRET=
