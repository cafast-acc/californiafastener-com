# California Fastener — env template
# Copy to .env.local for local dev. In Vercel, set the same vars under
# Project Settings → Environment Variables for Production + Preview + Development.

# ─── Supabase (Phase 1) ──────────────────────────────────
# From Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...replace-me...

# Server-only — bypasses RLS. NEVER expose. Used by seed scripts / webhooks
# in later phases. Phase 1 app code does NOT import this.
SUPABASE_SERVICE_ROLE_KEY=eyJ...replace-me...

# ─── Google Tag Manager (Phase 2) ────────────────────────
# Existing container ID from the Squarespace site. Loaded on public pages
# only — explicitly NOT on /admin or /studio. Leave unset to disable GTM.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ─── Google Analytics 4 (Phase 5) ────────────────────────
# Numeric property ID, e.g. 312345678. Get from GA4 → Admin → Property settings.
GA4_PROPERTY_ID=
# Service-account JSON key as a single-line string. Steps:
#  1. Create a Google Cloud project (or reuse existing)
#  2. Enable Google Analytics Data API
#  3. Create a service account, download the JSON key
#  4. In GA4 → Admin → Property Access Management, grant the service
#     account email Viewer access
#  5. Paste the entire JSON below on a single line (escape inner quotes).
GA4_SERVICE_ACCOUNT_JSON=

# ─── Jotform (Phase 3) ───────────────────────────────────
# API key from Jotform → My Account → API. Server-only; never exposed.
# Without it, /api/forms/quote accepts submissions in "deferred" mode
# (returns ok=true so the UX still works in dev).
JOTFORM_API_KEY=
# Form ID to receive /quote submissions. Defaults to the existing form
# (260995842557069) used by the spec-builder modal. Set this when you
# build a dedicated form with all the wizard fields — and update the
# QID map in src/app/api/forms/quote/route.ts to match.
JOTFORM_QUOTE_FORM_ID=
