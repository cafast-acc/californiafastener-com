# Copy to .env.local and fill in. Set the same values in Vercel
# (Production / Preview / Development scopes) before deploying.

# Sanity — public, safe to ship to the browser
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Sanity — server-only.
# Shared secret used to verify webhook signatures on /api/revalidate.
# Set the same string in Sanity Manage → API → Webhooks → secret.
# Generate with: openssl rand -hex 32
SANITY_WEBHOOK_SECRET=
